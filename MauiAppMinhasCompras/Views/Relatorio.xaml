<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio">

    <VerticalStackLayout Padding="10">

        <Label Text="Relatório de Compras"
               FontSize="20"
               HorizontalOptions="Center" />

        <Label Text="Data Inicial"/>
        <DatePicker x:Name="dt_inicio" />

        <Label Text="Data Final"/>
        <DatePicker x:Name="dt_fim" />

        <Button Text="Filtrar"
                Clicked="OnFiltrarClicked"/>

        <CollectionView x:Name="listaProdutos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Margin="5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Descricao}" FontAttributes="Bold"/>
                            <Label Text="{Binding Preco}"/>
                            <Label Text="{Binding DataCadastro, StringFormat='Data: {0:dd/MM/yyyy}'}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>